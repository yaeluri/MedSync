# ── Database ──────────────────────────────────────────────────────────
DB_HOST=10.10.248.140
DB_PORT=5432
DB_USER=your_postgres_user
DB_PASSWORD=your_postgres_password
DB_NAME=your_database_name

# ── Server ────────────────────────────────────────────────────────────
PORT=3000
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_to_a_different_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# ── Google Gemini (AI summaries + OCR) ───────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Google Cloud Speech-to-Text (voice recording transcription) ──────
# Path to the service account JSON key file on the server
GOOGLE_APPLICATION_CREDENTIALS=/opt/medsync/google-credentials.json
